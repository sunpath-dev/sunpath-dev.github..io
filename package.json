{
  "name": "sunpath",
  "version": "0.0.0",
  "private": true,
  "description": "Field intelligence for solar door-to-door teams.",
  "license": "MIT",
  "homepage": "https://sunpath.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/sunpath-dev/sunpath-dev.github.io"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "lint": "pnpm --filter web lint",
    "typecheck": "pnpm -r --parallel exec tsc --noEmit",
    "test": "pnpm -r test --if-present",
    "test:e2e": "playwright test",
    "build": "pnpm -r build",
    "dev": "pnpm --filter web dev",
    "ingest:parcels": "tsx scripts/ingest-parcels.ts",
    "import:hoa": "tsx scripts/import-hoa.ts",
    "supabase:deploy": "pwsh ./scripts/supabase-deploy.ps1",
    "github:secrets:set": "pwsh ./scripts/run-set-secrets.ps1",
    "github:secrets:list": "pwsh ./scripts/github-list-secrets.ps1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sunpath/parcel-adapters": "workspace:*",
    "@sunpath/shared": "workspace:*",
    "@supabase/supabase-js": "^2.45.0",
    "tsx": "^4.19.0"
  }
}
